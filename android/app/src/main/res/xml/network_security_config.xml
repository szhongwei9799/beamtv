<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 允许本地网络访问 (SMB, WebDAV, NAS 等) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.0.0/8</domain>
        <domain includeSubdomains="true">172.16.0.0/12</domain>
        <domain includeSubdomains="true">192.168.0.0/16</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

    <!-- 常用媒体服务域名 -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">picsum.photos</domain>
        <domain includeSubdomains="true">image.tmdb.org</domain>
        <domain includeSubdomains="true">api.themoviedb.org</domain>
        <domain includeSubdomains="true">tvapi.example.com</domain>
    </domain-config>

    <!-- 调试模式下允许明文 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>