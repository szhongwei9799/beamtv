<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 背景色 -->
    <item android:drawable="@color/beam_bg_marketing" />

    <!-- 中心 Logo -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center">
        <vector
            android:width="120dp"
            android:height="120dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <!-- 光线传播 Logo - 简化的光束图标 -->
            <path
                android:fillColor="@color/beam_brand_violet"
                android:pathData="M12,2L4,22h16L12,2z" />
            <path
                android:fillColor="@color/beam_brand_violet_hover"
                android:pathData="M12,6L8,18h8L12,6z" />
        </vector>
    </item>

    <!-- 底部版本号区域 -->
    <item
        android:gravity="bottom|center_horizontal"
        android:bottom="60dp">
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_version_text" />
    </item>
</layer-list>